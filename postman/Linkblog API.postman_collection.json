          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{handle}}/links/{{linkId}}",
              "host": ["{{baseUrl}}"],
              "path": ["{{handle}}", "links", "{{linkId}}"]
            },
            "description": "Delete a link by ID. Uses `linkId` variable. Clears `linkId` on success."
          },
          "response": []
        }
      ],
