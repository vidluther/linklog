    {
      "name": "Links",
      "item": [
        {
          "name": "Create Link",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "",
                  "pm.test('Response time is under 2000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Content-Type header is application/json', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('Response contains all required fields', function () {",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body).to.have.property('url');",
                  "    pm.expect(body).to.have.property('summary');",
                  "    pm.expect(body).to.have.property('created_at');",
                  "    pm.expect(body).to.have.property('updated_at');",
                  "});",
                  "",
                  "pm.test('ID is a number', function () {",
                  "    pm.expect(body.id).to.be.a('number');",
                  "    pm.expect(Number.isInteger(body.id)).to.be.true;",
                  "});",
                  "",
                  "pm.test('URL is a string', function () {",
                  "    pm.expect(body.url).to.be.a('string');",
                  "});",
                  "",
                  "pm.test('URL has valid format', function () {",
                  "    pm.expect(body.url).to.match(/^https?:\\/\\/.+/);",
                  "});",
                  "",
                  "pm.test('created_at is valid ISO 8601 timestamp', function () {",
                  "    const date = new Date(body.created_at);",
                  "    pm.expect(date.toString()).to.not.equal('Invalid Date');",
                  "});",
                  "",
                  "pm.test('updated_at is valid ISO 8601 timestamp', function () {",
                  "    const date = new Date(body.updated_at);",
                  "    pm.expect(date.toString()).to.not.equal('Invalid Date');",
                  "});",
                  "",
                  "if (body.id) { pm.environment.set('linkId', body.id); }"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"url\": \"{{$randomUrl}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/{{handle}}/links",
              "host": ["{{baseUrl}}"],
              "path": ["{{handle}}", "links"]
            },
            "description": "Create a new bookmarked link. On success, auto-saves the returned `id` to `linkId`."
          },
          "response": []
        },
        {
          "name": "List All Links",
          "event": [
