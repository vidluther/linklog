{
  "name": "linkblog",
  "version": "0.0.2",
  "description": "My personal linkblog",
  "author": "Vid Luther (vid@luther.io)",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "nest build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "test:cov": "vitest --coverage",
    "test:debug": "vitest --run",
    "test:e2e": "vitest --config ./vitest.config.e2e.ts",
    "build:extension": "pnpm --filter linkblog-extension build",
    "clean:extension": "pnpm --filter linkblog-extension clean"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.13",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.13",
    "@nestjs/mapped-types": "*",
    "@nestjs/platform-express": "^11.1.13",
    "@supabase/supabase-js": "^2.95.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "feed": "^5.2.0",
    "nestjs-pino": "^4.6.0",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.13",
    "@swc/core": "^1.15.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.10",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "globals": "^16.5.0",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supabase": "^2.76.3",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0",
    "vite-tsconfig-paths": "^5.1.0",
    "vitest": "^2.1.9"
  }
}
